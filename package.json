{
  "name": "toybox-fps-arena",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node server.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server.mjs",
    "preview": "NODE_ENV=production node server.mjs",
    "check": "tsc --noEmit",
    "ios:add": "npm run build && npx cap add ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "test:smoke": "node scripts/smoke-multiplayer.mjs",
    "test:controls": "node scripts/control-physics-test.mjs",
    "test:systems": "node scripts/gameplay-systems-test.mjs",
    "test:economy": "node scripts/economy-systems-test.mjs",
    "test:progression": "node scripts/progression-systems-test.mjs",
    "test:account-live": "node scripts/account-progression-live-test.mjs",
    "test:network": "node scripts/network-systems-test.mjs",
    "test:runtime-memory": "node scripts/runtime-memory-systems-test.mjs",
    "test:runtime-memory-live": "node scripts/runtime-memory-live-test.mjs",
    "test:render": "node scripts/render-systems-test.mjs",
    "test:combat": "node scripts/combat-systems-test.mjs",
    "test:movement": "node scripts/movement-systems-test.mjs",
    "test:world": "node scripts/world-systems-test.mjs",
    "test:match": "node scripts/match-systems-test.mjs",
    "test:match-live": "node scripts/match-live-test.mjs",
    "test:baccarat": "node scripts/baccarat-systems-test.mjs",
    "test:baccarat-live": "node scripts/baccarat-live-test.mjs",
    "test:vertical": "node scripts/vertical-systems-test.mjs",
    "test:vertical-live": "node scripts/vertical-live-test.mjs",
    "test:world-live": "node scripts/world-live-test.mjs",
    "test:ai": "node scripts/ai-systems-test.mjs",
    "test:ai-live": "node scripts/ai-live-test.mjs",
    "verify:public": "node scripts/verify-public-url.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "lucide": "^0.468.0",
    "three": "^0.166.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^20.14.9",
    "@types/three": "^0.185.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
